
set $mod Mod4

font pango:scientifica 8

set_from_resource $background background #1d1f21
set_from_resource $foreground foreground #c5c8c6
set_from_resource $color1 color1 #cc6666

client.focused          $foreground $foreground $background $foreground
client.unfocused        $background $background $foreground $background
client.urgent           $color1     $color1     $foreground $background

exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id picom --experimental-backends
exec --no-startup-id eww daemon
exec --no-startup-id dunst
bindsym $mod+Shift+i exec i3lock

exec --no-startup-id nm-applet
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id wal -R

set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

bindsym $Mod+w exec --no-startup-id alacritty --title WallpaperSelector -e ~/.config/polybar/scripts/wallpaper_selector.sh
bindsym $Mod+z exec --no-startup-id ~/.config/polybar/rofi_app/launcherapp.sh
bindsym $Mod+s exec --no-startup-id ~/.config/polybar/rofi_app/screenshot.sh

exec_always --no-startup-id sh -c "killall picom; picom --config ~/.config/polybar/picom.conf &"
exec_always --no-startup-id bash ~/.config/polybar/launch.sh
bindsym $Mod+x exec --no-startup-id ~/.config/polybar/rofi_app/powermenu.sh
#exec --no-startup-id xrandr --output DisplayPort-0 --scale 1.406x1.406

bindsym $mod+Return exec alacritty
bindsym $mod+q exec --no-startup-id /home/mrtatanai/.local/share/zen/zen
bindsym $mod+Shift+q kill

bindsym $mod+Tab focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle

floating_modifier $mod
tiling_drag modifier titlebar

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+Shift+r restart
bindsym $mod+Escape exec --no-startup-id bash -c 'pgrep -x eww && eww close-all'

#for_window [class=".*"] floating enable
for_window [class=".*"] border pixel 2
gaps inner 0

for_window [title="^(Picture-in-Picture|PiP)$"] floating enable, sticky enable
for_window [class="mpv"] floating enable, sticky enable
for_window [title="cava"] floating enable, sticky enable, resize set 250 150
for_window [title="WallpaperSelector"] floating enable, sticky enable, resize set 700 400, move position center
for_window [title="Alacritty"] floating enable
